			{
				"cell_type": "code",
				"source": [
					"def count_new_items_recursive(path: str, max_date: datetime) -> int:\r\n",
					"    count = 0\r\n",
					"\r\n",
					"    try:\r\n",
					"        items = mssparkutils.fs.ls(path)\r\n",
					"\r\n",
					"        for item in items:\r\n",
					"            # ✅ correct property\r\n",
					"            item_time = datetime.fromtimestamp(item.modifyTime / 1000)\r\n",
					"\r\n",
					"            if item.isDir:\r\n",
					"                # go into subfolders\r\n",
					"                count += count_new_items_recursive(item.path, max_date)\r\n",
					"            else:\r\n",
					"                # count only files after max date\r\n",
					"                if max_date is None or item_time > max_date:\r\n",
					"                    count += 1\r\n",
					"\r\n",
					"    except Exception as e:\r\n",
					"        print(f\"Error reading path {path}: {e}\")\r\n",
					"\r\n",
					"    return count"
				],
				"execution_count": 36
			},
