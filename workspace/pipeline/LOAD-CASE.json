{
	"name": "LOAD-CASE",
	"properties": {
		"activities": [
			{
				"name": "Case table",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": "MPESC-TRANSFORM/case-merged-sample-row",
							"wildcardFileName": "*.csv",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "upsert",
						"upsertSettings": {
							"useTempDB": true,
							"keys": [
								"legacyCaseId"
							]
						},
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "caseCreateDate"
								},
								"sink": {
									"name": "createdDate"
								}
							},
							{
								"source": {
									"name": "caseCloseDate"
								},
								"sink": {
									"name": "closedDate"
								}
							},
							{
								"source": {
									"name": "caseTypeName"
								},
								"sink": {
									"name": "typeId"
								}
							},
							{
								"source": {
									"name": "hznReference"
								},
								"sink": {
									"name": "historicalReference"
								}
							},
							{
								"source": {
									"name": "caseOfficerId"
								},
								"sink": {
									"name": "caseOfficerId"
								}
							},
							{
								"source": {
									"name": "linkedStatus"
								},
								"sink": {
									"name": "linkedCases"
								}
							},
							{
								"source": {
									"name": "fileLocation"
								},
								"sink": {
									"name": "filesLocation"
								}
							},
							{
								"source": {
									"name": "band_id"
								},
								"sink": {
									"name": "inspectorBandId"
								}
							},
							{
								"source": {
									"name": "caseReceiptDate"
								},
								"sink": {
									"name": "receivedDate"
								}
							},
							{
								"source": {
									"name": "caseDisplayName"
								},
								"sink": {
									"name": "name"
								}
							},
							{
								"source": {
									"name": "caseNodeId"
								},
								"sink": {
									"name": "legacyCaseId"
								}
							},
							{
								"source": {
									"name": "addressGuid"
								},
								"sink": {
									"name": "siteAddressId"
								}
							},
							{
								"source": {
									"name": "caseGuid"
								},
								"sink": {
									"name": "id"
								}
							},
							{
								"source": {
									"name": "priority"
								},
								"sink": {
									"name": "priorityId"
								}
							},
							{
								"source": {
									"name": "advertisedModificationId"
								},
								"sink": {
									"name": "advertisedModificationId"
								}
							},
							{
								"source": {
									"name": "processingStateId"
								},
								"sink": {
									"name": "statusId"
								}
							},
							{
								"source": {
									"name": "newCaseReference"
								},
								"sink": {
									"name": "reference"
								}
							},
							{
								"source": {
									"name": "applicationSubtypeMapped"
								},
								"sink": {
									"name": "subTypeId"
								}
							},
							{
								"source": {
									"name": "actId"
								},
								"sink": {
									"name": "actId"
								}
							},
							{
								"source": {
									"name": "sectionId"
								},
								"sink": {
									"name": "sectionId"
								}
							},
							{
								"source": {
									"name": "nameOfCommonOrVillageGreen"
								},
								"sink": {
									"name": "location"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "MPESC_Case",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "CASE_MPESC",
						"type": "DatasetReference"
					}
				]
			}
		],
		"folder": {
			"name": "archive/Horizon Migration/MPESC-LOAD"
		},
		"annotations": []
	}
}