{
	"name": "pln_log_to_appins",
	"properties": {
		"activities": [
			{
				"name": "Set Sample Data",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "body",
					"value": {
						"value": "{\"Stage\":\"Completed\",\"PipelineName\":\"pln_test_pipeline\",\"PipelineRunID\":\"12345-abc\",\"StartTime\":\"2026-06-16T10:00:00Z\",\"EndTime\":\"2026-06-16T10:05:00Z\",\"Inserts\":\"100\",\"Updates\":\"20\",\"Deletes\":\"5\",\"ErrorMessage\":\"\",\"StatusMessage\":\"Test execution successful\",\"PipelineTriggerID\":\"trigger123\",\"PipelineTriggerName\":\"manual\",\"PipelineTriggerType\":\"Manual\",\"PipelineTriggeredbyPipelineName\":\"parent_pipeline\",\"PipelineTriggeredbyPipelineRunID\":\"parent_run_001\",\"PipelineExecutionTimeInSec\":\"300\",\"ActivityType\":\"Copy\",\"StatusCode\":\"200\",\"DurationSeconds\":\"300\"}",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Set iKey",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Set Sample Data",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "app_ins_ikey",
					"value": {
						"value": "YOUR-INSTRUMENTATION-KEY-HERE",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Log to App Insights",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "Set iKey",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"headers": {
						"Content-Type": "application/json"
					},
					"url": "https://uksouth-1.in.applicationinsights.azure.com/v2/track",
					"body": {
						"value": "@concat('{\"name\":\"AppEvents\",\"time\":\"', utcNow(), '\",\"iKey\":\"', variables('app_ins_ikey'), '\",\"data\":{\"baseType\":\"EventData\",\"baseData\":{\"name\":\"ODW_Master_Pipeline_Logs\",\"properties\":', variables('body'), '}}}')",
						"type": "Expression"
					}
				}
			}
		],
		"variables": {
			"body": {
				"type": "String"
			},
			"app_ins_ikey": {
				"type": "String"
			}
		},
		"annotations": []
	}
}