{
	"name": "LOAD-CASE-INSPECTOR-CASE",
	"properties": {
		"activities": [
			{
				"name": "CaseUser",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": "MPESC-TRANSFORM/User/inspector_case_map",
							"wildcardFileName": "*.csv",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "upsert",
						"upsertSettings": {
							"useTempDB": true,
							"keys": [
								"id"
							]
						},
						"sqlWriterUseTableLock": false,
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "caseId"
								},
								"sink": {
									"name": "caseId"
								}
							},
							{
								"source": {
									"name": "userId"
								},
								"sink": {
									"name": "inspectorId"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "MPESC_INSPECTORCASE",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "INSPECTOR_MPESC",
						"type": "DatasetReference"
					}
				]
			}
		],
		"folder": {
			"name": "Horizon Migration/MPESC-LOAD"
		},
		"annotations": []
	}
}