{
	"name": "ds_odw_generic",
	"properties": {
		"description": "Parameterised generic dataset for any ODW.* table in the mipins target DB (via ls_sql_mipins).",
		"parameters": {
			"schemaName": {
				"type": "string",
				"defaultValue": "ODW"
			},
			"tableName": {
				"type": "string"
			}
		},
		"annotations": [],
		"linkedServiceName": {
			"referenceName": "ls_sql_mipins",
			"type": "LinkedServiceReference"
		},
		"type": "AzureSqlTable",
		"typeProperties": {
			"schema": {
				"value": "@dataset().schemaName",
				"type": "Expression"
			},
			"table": {
				"value": "@dataset().tableName",
				"type": "Expression"
			}
		}
	}
}