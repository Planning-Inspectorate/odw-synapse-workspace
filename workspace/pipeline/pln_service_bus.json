							"description": "Appends an entry to the run-time watermark_json array with has_new_data and message_enqueued_time_utc for this entity.",
							"type": "AppendVariable",
							"dependsOn": [
								{
									"activity": "Set has_new_data json",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"variableName": "watermark_json",
								"value": {
									"value": "@json(concat('{\"entity_name\":\"', item().entity_name, '\",\"has_new_data\":', variables('has_new_data'), ',\"message_enqueued_time_utc\":\"', coalesce(json(coalesce(activity('Raw to Std').output.status.output.result.exitValue, '{}'))?['max_message_enqueued_time_utc'], ''), '\",\"records_ingested\":', string(coalesce(json(coalesce(activity('Raw to Std').output.status.output.result.exitValue, '{}'))?['table_details']?[0]?['insert_count'], 0)), ',\"custom_harmonised_notebooks\":', if(empty(item().custom_harmonised_notebooks), '[]', string(item().custom_harmonised_notebooks)), '}'))",
									"type": "Expression"
								}
							}
						},
						{
							"name": "Set pipeline name",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "Set entity_name",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "pipeline name",
								"value": {
									"value": "@concat(concat(pipeline().Pipeline, ' - '), variables('entity_name'))",
									"type": "Expression"
								}
							}
						}
					]
				}
			},
			{
				"name": "Filter watermark has new data",
				"description": "Filters the run-time watermark_json to entities that received new data, so only those proceed to Std to Hrm and custom harmonised.",
				"type": "Filter",
				"dependsOn": [
					{
						"activity": "ForEach - Raw to Std",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@variables('watermark_json')",
						"type": "Expression"
					},
					"condition": {
						"value": "@equals(item().has_new_data, true)",
						"type": "Expression"
					}
				}
			}
		],
		"parameters": {
			"apps_insights_ikey": {
				"type": "string"
			},
			"Key_Vault_Url": {
				"type": "string"
			},
			"webhook_url": {
				"type": "string"
			},
			"entity_name_array": {
				"type": "array",
				"defaultValue": [
					""
				]
			}
		},
		"variables": {
			"entity_name": {
				"type": "String",
				"defaultValue": "test"
			},
			"pipeline name": {
				"type": "String",
				"defaultValue": "test"
			},
			"has_new_data": {
				"type": "String",
				"defaultValue": "false"
			},
			"watermark_json": {
				"type": "Array"
			}
		},
		"folder": {
			"name": "utils/Master"
		},
		"annotations": []
	}
}