{
	"name": "USERS_MPESC",
	"properties": {
		"activities": [
			{
				"name": "Users",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"sqlReaderQuery": "SELECT DISTINCT\n    k.ID,\n    k.Name,\n    k.FirstName,\n    k.LastName,\n    k.MailAddress\nFROM dbo.[Horizon_CaseNotes] cn\nJOIN dbo.KUAF k\n    ON cn.CreatedBy = k.ID\nWHERE k.ID IS NOT NULL;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".csv"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "users",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "USERScsv",
						"type": "DatasetReference"
					}
				]
			}
		],
		"folder": {
			"name": "Horizon Migration/MPESC-EXTRACT"
		},
		"annotations": []
	}
}