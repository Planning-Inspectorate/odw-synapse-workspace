{
	"name": "ds_standardised_generic",
	"properties": {
		"description": "Parameterised generic dataset for any dbo.* table in odw_standardised_db (via ls_ssql_builtin).",
		"parameters": {
			"schemaName": {
				"type": "string",
				"defaultValue": "dbo"
			},
			"tableName": {
				"type": "string"
			}
		},
		"annotations": [],
		"linkedServiceName": {
			"referenceName": "ls_ssql_builtin",
			"type": "LinkedServiceReference"
		},
		"type": "AzureSqlTable",
		"typeProperties": {
			"schema": {
				"value": "@dataset().schemaName",
				"type": "Expression"
			},
			"table": {
				"value": "@dataset().tableName",
				"type": "Expression"
			}
		}
	}
}