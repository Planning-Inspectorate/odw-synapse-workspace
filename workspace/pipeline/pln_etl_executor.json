{
	"name": "pln_etl_executor",
	"properties": {
		"activities": [
			{
				"name": "Inner loop",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.entity_stages",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Execute ETL",
							"type": "SynapseNotebook",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"notebook": {
									"referenceName": "py_etl_executor",
									"type": "NotebookReference"
								},
								"parameters": {
									"input_arguments": {
										"value": {
											"value": "@item().kwargs",
											"type": "Expression"
										},
										"type": "string"
									}
								},
								"snapshot": true
							}
						}
					]
				}
			}
		],
		"parameters": {
			"entity_stages": {
				"type": "array"
			}
		},
		"folder": {
			"name": "utils"
		},
		"annotations": []
	}
}