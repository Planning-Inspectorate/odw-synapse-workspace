						"activity": "Record_Count",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.02:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[Live].[upd_dim_source_system]",
					"storedProcedureParameters": {
						"refresh_date": {
							"value": {
								"value": "@utcNow('yyyy-MM-ddTHH:mm:ss.fff')",
								"type": "Expression"
							},
							"type": "DateTime"
						},
						"source_system": {
							"value": "NSIP Project",
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "ls_sql_mipins",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "Sp_log_success",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [
					{
						"activity": "SP_update dim_source_system",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.02:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[Audit].[usp_addETLLog]",
					"storedProcedureParameters": {
						"Description": {
							"value": "NSIP_curated_mipins_pipeline_completed",
							"type": "String"
						},
						"ErrorMessage": {
							"value": null,
							"type": "String"
						},
						"LogType": {
							"value": "2",
							"type": "String"
						},
						"Param1Value": {
							"value": null,
							"type": "String"
						},
						"RowCount": {
							"value": {
								"value": "@variables('RowCount_NSIP Project')",
								"type": "Expression"
							},
							"type": "Int32"
						},
						"RunId": {
							"value": {
								"value": "@activity('Lookup-LogStart').output.firstRow.Runid",
								"type": "Expression"
							},
							"type": "Int32"
						},
						"Source": {
							"value": "NSIP Project",
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "ls_sql_mipins",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "Error_NSIP Project",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "SP_update dim_source_system",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "Error_NSIP",
					"value": {
						"value": "@replace(concat(activity('Lookup-LogStart').Error?.message,'|',activity('Copy NSIP Project').Error?.message,'|',activity('SP_update dim_source_system').Error?.message),'|','')",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Sp_log_failed",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [
					{
						"activity": "Error_NSIP Project",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.02:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[Audit].[usp_addETLLog]",
					"storedProcedureParameters": {
						"Description": {
							"value": "NSIP_curated_mipins_pipeline_failed",
							"type": "String"
						},
						"ErrorMessage": {
							"value": {
								"value": "@variables('Error_NSIP')",
								"type": "Expression"
							},
							"type": "String"
						},
						"LogType": {
							"value": "2",
							"type": "String"
						},
						"Param1Value": {
							"value": null,
							"type": "String"
						},
						"RowCount": {
							"value": null,
							"type": "Int32"
						},
						"RunId": {
							"value": {
								"value": "@activity('Lookup-LogStart').output.firstRow.Runid",
								"type": "Expression"
							},
							"type": "Int32"
						},
						"Source": {
							"value": "NSIP Project",
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "ls_sql_mipins",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "Record completed NSIP to mipins",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "Set_PipelineStatus_Success",
						"dependencyConditions": [
							"Succeeded",
							"Skipped"
						]
					},
					{
						"activity": "Set_PipelineStatus_Failed",
						"dependencyConditions": [
							"Succeeded",
							"Skipped"
						]
					},
					{
						"activity": "Sp_log_success",
						"dependencyConditions": [
							"Succeeded",
							"Skipped"
						]
					},
					{
						"activity": "Sp_log_failed",
						"dependencyConditions": [
							"Succeeded",
							"Skipped"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pln_log_to_appins",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"Stage": {
							"value": "@if(or(equals(activity('Copy NSIP Project')?.Error?.Message,''),equals(activity('Copy NSIP Project')?.Error?.Message,null)),'Success','Failed')",
							"type": "Expression"
						},
						"PipelineName": {
							"value": "@pipeline().Pipeline",
							"type": "Expression"
						},
						"PipelineRunID": {
							"value": "@pipeline().RunId",
							"type": "Expression"
						},
						"StartTime": {
							"value": "@variables('StartTime')",
							"type": "Expression"
						},
						"EndTime": {
							"value": "@utcNow()",
							"type": "Expression"
						},
						"Inserts": {
							"value": "@if(or(equals(activity('Copy NSIP Project')?.Error?.Message,''),equals(activity('Copy NSIP Project')?.Error?.Message,null)),activity('Copy NSIP Project').output.rowsCopied,0)",
							"type": "Expression"
						},
						"ErrorMessage": {
							"value": "@if(or(equals(activity('Copy NSIP Project')?.Error?.Message,''),equals(activity('Copy NSIP Project')?.Error?.Message,null)),'',activity('Copy NSIP Project')?.Error?.Message)",
							"type": "Expression"
						},
						"StatusMessage": {
							"value": "@if(or(equals(activity('Copy NSIP Project')?.Error?.Message,''),equals(activity('Copy NSIP Project')?.Error?.Message,null)),'Successfully copied NSIP data','Failed copying NSIP data')",
							"type": "Expression"
						},
						"PipelineTriggerID": {
							"value": "@pipeline().TriggerId",
							"type": "Expression"
						},
						"PipelineTriggerName": {
							"value": "@pipeline().TriggerName",
							"type": "Expression"
						},
						"PipelineTriggerType": {
							"value": "@pipeline().TriggerType",
							"type": "Expression"
						},
						"PipelineTriggeredbyPipelineName": "@coalesce(pipeline()?.TriggeredByPipelineName, '')",
						"PipelineTriggeredbyPipelineRunID": "@coalesce(pipeline()?.TriggeredByPipelineRunId, '')",
						"PipelineExecutionTimeInSec": "@div(sub(ticks(utcNow()), ticks(variables('StartTime'))), 10000000)",
						"ActivityType": {
							"value": "@concat('NSIP Project',' Activity')",
							"type": "Expression"
						},
						"DurationSeconds": {
							"value": "@div(sub(ticks(utcNow()), ticks(variables('StartTime'))), 10000000)",
							"type": "Expression"
						},
						"StatusCode": {
							"value": "@if(or(equals(activity('Copy NSIP Project')?.Error?.Message,''),equals(activity('Copy NSIP Project')?.Error?.Message,null)),'200','500')",
							"type": "Expression"
						},
						"AppInsIKey": {
							"value": "@pipeline().parameters.apps_insights_ikey",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "Check Pipeline Status",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Record completed NSIP to mipins",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@equals(variables('PipelineStatus'),'Failed')",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "Send NSIP failure notification",
							"type": "ExecutePipeline",
							"dependsOn": [],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pln_utl_Send_Teams_Message",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"pipelineRunId": {
										"value": "@pipeline().RunId",
										"type": "Expression"
									},
									"activityName": {
										"value": "@pipeline().Pipeline",
										"type": "Expression"
									},
									"activityStatus": "Failed",
									"activityMessage": {
										"value": "@variables('errorMessage')",
										"type": "Expression"
									}
								}
							}
						},
						{
							"name": "Fail_Pipeline_On_Error",
							"type": "Fail",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"message": "Pipeline failed. Check AppInsights logs.",
								"errorCode": "PIPELINE_FAILED"
							}
						}
					]
				}
			},
			{
				"name": "Check Pipeline Status_copy1",
				"type": "IfCondition",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@equals(variables('PipelineStatus'), 'Failed')",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "Fail Pipeline_copy1",
							"type": "Fail",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"message": {
									"value": "@concat('Pipeline failed: ', variables('Error_Has'))",
									"type": "Expression"
								},
								"errorCode": "500"
							}
						}
					]
				}
			}
		],
		"parameters": {
			"apps_insights_ikey": {
				"type": "string",
				"defaultValue": "87864c3b-0d8b-4a98-b2c4-596ddf8fe123"
			}
		},
		"variables": {
			"RowCount_NSIP Project": {
				"type": "Integer"
			},
			"PipelineStatus": {
				"type": "String",
				"defaultValue": "Success"
			},
			"errorMessage": {
				"type": "String"
			},
			"StartTime": {
				"type": "String"
			},
			"Error_NSIP": {
				"type": "String"
			}
		},
		"folder": {
			"name": "nsip project"
		},
		"annotations": []
	}
}