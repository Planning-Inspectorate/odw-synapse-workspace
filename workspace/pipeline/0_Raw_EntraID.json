			},
			"apps_insights_ikey": {
				"type": "string"
			}
		},
		"variables": {
			"entraIDRecordLoadingStartTime": {
				"type": "String"
			},
			"execution_logs": {
				"type": "String"
			},
			"temp_var": {
				"type": "String"
			},
			"w": {
				"type": "String"
			},
			"errorMsg": {
