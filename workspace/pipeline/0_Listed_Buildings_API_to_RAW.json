{
	"name": "0_Listed_Buildings_API_to_RAW",
	"properties": {
		"activities": [
			{
				"name": "ListedBuilding",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "Set Environment",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:10:00",
					"retry": 3,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET"
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "arrayOfObjects"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "ListedBuildings",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "listed_building",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "ListedBuildingOutline",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "ListedBuilding",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:10:00",
					"retry": 3,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "JsonWriteSettings",
							"filePattern": "arrayOfObjects"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "ListedBuildingOutline",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "listed_building_outline",
						"type": "DatasetReference"
					}
				]
			},
			{
				"name": "Set Environment",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "Set_Pipeline_Start_Time",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "env",
					"value": {
						"value": "@if(\n    equals(\n        pipeline().DataFactory,\n        'pins-synw-odw-prod-uks'\n    ),\n    'PROD',\n    if(\n        equals(\n            pipeline().DataFactory,\n            'pins-synw-odw-test-uks'\n        ),\n        'TEST',\n        if(\n            equals(\n                pipeline().DataFactory,\n                'pins-synw-odw-build-uks'\n            ),\n            'BUILD',\n            'DEV'\n        )\n    )\n)",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Set_Pipeline_Start_Time",
				"type": "SetVariable",
				"dependsOn": [],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "ListedBuilding_Start_Time",
					"value": {
						"value": "@utcNow()",
						"type": "Expression"
					}
				}
			},
			{
				"name": "Record ListedBuilding Logs",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "ListedBuilding",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pln_log_to_appins",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"Stage": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuilding')?.Error?.Message, ''),\n        equals(activity('ListedBuilding')?.Error?.Message, null)\n    ),\n    'Success',\n    'Failed'\n)",
							"type": "Expression"
						},
						"PipelineName": {
							"value": "@pipeline().Pipeline",
							"type": "Expression"
						},
						"PipelineRunID": {
							"value": "@pipeline().RunId",
							"type": "Expression"
						},
						"StartTime": {
							"value": "@variables('ListedBuilding_Start_Time')",
							"type": "Expression"
						},
						"EndTime": {
							"value": "@utcNow()",
							"type": "Expression"
						},
						"Inserts": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuilding')?.Error?.Message, ''),\n        equals(activity('ListedBuilding')?.Error?.Message, null)\n    ),\n    activity('ListedBuilding').output.rowsCopied,\n    ''\n)\n",
							"type": "Expression"
						},
						"ErrorMessage": {
							"value": "@{if(or(equals(activity('ListedBuilding')?.Error?.Message, ''), equals(activity('ListedBuilding')?.Error?.Message, null)), '', activity('ListedBuilding')?.Error?.Message)}",
							"type": "Expression"
						},
						"StatusMessage": {
							"value": "Data Copied From listed-building.json To raw_listed_building.json'",
							"type": "Expression"
						},
						"PipelineTriggerID": {
							"value": "@pipeline().TriggerId",
							"type": "Expression"
						},
						"PipelineTriggerName": {
							"value": "@pipeline().TriggerName",
							"type": "Expression"
						},
						"PipelineTriggerType": {
							"value": "@pipeline().TriggerType",
							"type": "Expression"
						},
						"PipelineTriggeredbyPipelineName": {
							"value": "@pipeline()?.TriggeredByPipelineName",
							"type": "Expression"
						},
						"PipelineTriggeredbyPipelineRunID": {
							"value": "@pipeline()?.TriggeredByPipelineRunId",
							"type": "Expression"
						},
						"ActivityType": {
							"value": "Copy Activity",
							"type": "Expression"
						},
						"DurationSeconds": {
							"value": "@div(sub(ticks(utcNow()), ticks(variables('ListedBuilding_Start_Time'))), 10000000)",
							"type": "Expression"
						},
						"StatusCode": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuilding')?.Error?.Message, ''),\n        equals(activity('ListedBuilding')?.Error?.Message, null)\n    ),\n    '200',\n    '500'\n)",
							"type": "Expression"
						},
						"AppInsIKey": {
							"value": "@pipeline().parameters.apps_insights_ikey",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "Record ListedBuildingOutline Logs",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "ListedBuildingOutline",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "pln_log_to_appins",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"Stage": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuildingOutline')?.Error?.Message, ''),\n        equals(activity('ListedBuildingOutline')?.Error?.Message, null)\n    ),\n    'Success',\n    'Failed'\n) ",
							"type": "Expression"
						},
						"PipelineName": {
							"value": "@pipeline().Pipeline",
							"type": "Expression"
						},
						"PipelineRunID": {
							"value": "@pipeline().RunId",
							"type": "Expression"
						},
						"StartTime": {
							"value": "@variables('ListedBuilding_Start_Time')",
							"type": "Expression"
						},
						"EndTime": {
							"value": "@utcNow()",
							"type": "Expression"
						},
						"Inserts": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuildingOutline')?.Error?.Message, ''),\n        equals(activity('ListedBuildingOutline')?.Error?.Message, null)\n    ),\n    activity('ListedBuildingOutline').output.rowsCopied,\n    ''\n)\n",
							"type": "Expression"
						},
						"ErrorMessage": {
							"value": "@{if(or(equals(activity('ListedBuildingOutline')?.Error?.Message, ''), equals(activity('ListedBuildingOutline')?.Error?.Message, null)), '', activity('ListedBuildingOutline')?.Error?.Message)}",
							"type": "Expression"
						},
						"StatusMessage": {
							"value": "Data Copied From listed-building.json To raw_listed_building.json'",
							"type": "Expression"
						},
						"PipelineTriggerID": {
							"value": "@pipeline().TriggerId",
							"type": "Expression"
						},
						"PipelineTriggerName": {
							"value": "@pipeline().TriggerName",
							"type": "Expression"
						},
						"PipelineTriggerType": {
							"value": "@pipeline().TriggerType",
							"type": "Expression"
						},
						"PipelineTriggeredbyPipelineName": {
							"value": "@pipeline()?.TriggeredByPipelineName",
							"type": "Expression"
						},
						"PipelineTriggeredbyPipelineRunID": {
							"value": "@pipeline()?.TriggeredByPipelineRunId",
							"type": "Expression"
						},
						"ActivityType": {
							"value": "Copy Activity",
							"type": "Expression"
						},
						"DurationSeconds": {
							"value": "@div(sub(ticks(utcNow()), ticks(variables('ListedBuilding_Start_Time'))), 10000000)",
							"type": "Expression"
						},
						"StatusCode": {
							"value": "@if(\n    or(\n        equals(activity('ListedBuildingOutline')?.Error?.Message, ''),\n        equals(activity('ListedBuildingOutline')?.Error?.Message, null)\n    ),\n    '200',\n    '500'\n) ",
							"type": "Expression"
						},
						"AppInsIKey": {
							"value": "@pipeline().parameters.apps_insights_ikey",
							"type": "Expression"
						}
					}
				}
			}
		],
		"parameters": {
			"apps_insights_ikey": {
				"type": "string",
				"defaultValue": "87864c3b-0d8b-4a98-b2c4-596ddf8fe123"
			}
		},
		"variables": {
			"env": {
				"type": "String"
			},
			"app_ins_ikey": {
				"type": "String"
			},
			"ListedBuilding_Start_Time": {
				"type": "String"
			}
		},
		"folder": {
			"name": "listed buildings/layers/0-raw"
		},
		"annotations": []
	}
}