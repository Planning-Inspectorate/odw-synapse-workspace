{
	"name": "pln_etl_orchestrator",
	"properties": {
		"activities": [
			{
				"name": "Gather stages to execute",
				"type": "SynapseNotebook",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebook": {
						"referenceName": "py_etl_orchestrator",
						"type": "NotebookReference"
					},
					"parameters": {
						"entity_stages_to_run": {
							"value": {
								"value": "@string(pipeline().parameters.stages_to_execute)",
								"type": "Expression"
							},
							"type": "string"
						},
						"run_id": {
							"value": {
								"value": "@pipeline().parameters.run_id",
								"type": "Expression"
							},
							"type": "string"
						},
						"config_file": {
							"value": {
								"value": "@pipeline().parameters.override_config_file",
								"type": "Expression"
							},
							"type": "string"
						}
					},
					"snapshot": true,
					"sparkPool": {
						"referenceName": "pinssynspodw35",
						"type": "BigDataPoolReference"
					},
					"conf": {
						"spark.dynamicAllocation.enabled": null,
						"spark.dynamicAllocation.minExecutors": null,
						"spark.dynamicAllocation.maxExecutors": null
					},
					"numExecutors": null
				}
			},
			{
				"name": "Outer loop",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "Gather stages to execute",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@json(\n    activity('Gather stages to execute').output.status.Output.result.exitValue\n)",
						"type": "Expression"
					},
					"isSequential": true,
					"activities": [
						{
							"name": "Execute inner loop",
							"type": "ExecutePipeline",
							"dependsOn": [
								{
									"activity": "Filter steps with failed dependencies",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "pln_etl_executor",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
									"entity_stages": {
										"value": "@json(\n    activity('Filter steps with failed dependencies').output.status.Output.result.exitValue\n)",
										"type": "Expression"
									},
									"run_id": {
										"value": "@pipeline().parameters.run_id",
										"type": "Expression"
									}
								}
							}
						},
						{
							"name": "Filter steps with failed dependencies",
							"description": "Filter out the elements from the current batch that have failed dependencies",
							"type": "SynapseNotebook",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"notebook": {
									"referenceName": "py_etl_batch_filter",
									"type": "NotebookReference"
								},
								"parameters": {
									"config_batch": {
										"value": {
											"value": "@string(item())",
											"type": "Expression"
										},
										"type": "string"
									},
									"run_id": {
										"value": {
											"value": "@pipeline().parameters.run_id",
											"type": "Expression"
										},
										"type": "string"
									}
								},
								"snapshot": true,
								"sparkPool": {
									"referenceName": "pinssynspodw35",
									"type": "BigDataPoolReference"
								},
								"conf": {
									"spark.dynamicAllocation.enabled": null,
									"spark.dynamicAllocation.minExecutors": null,
									"spark.dynamicAllocation.maxExecutors": null
								},
								"numExecutors": null
							}
						},
						{
							"name": "Append batch failures",
							"type": "AppendVariable",
							"dependsOn": [
								{
									"activity": "Execute inner loop",
									"dependencyConditions": [
										"Failed"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"variableName": "batchFailures",
								"value": {
									"value": "@string(\n    activity('Execute inner loop').error?.message\n)",
									"type": "Expression"
								}
							}
						},
						{
							"name": "Append batch preprocessing failures",
							"type": "AppendVariable",
							"dependsOn": [
								{
									"activity": "Filter steps with failed dependencies",
									"dependencyConditions": [
										"Failed"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"variableName": "batchFailures",
								"value": {
									"value": "@string(activity('Filter steps with failed dependencies').error.message)",
									"type": "Expression"
								}
							}
						},
						{
							"name": "Append batch preprocessing failures",
							"type": "AppendVariable",
							"dependsOn": [
								{
									"activity": "Filter steps with failed dependencies",
									"dependencyConditions": [
										"Failed"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"variableName": "batchFailures",
								"value": {
									"value": "@string(activity('Filter steps with failed dependencies').error.message)",
									"type": "Expression"
								}
							}
						}
					]
				}
			},
			{
				"name": "If failure detected",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "Outer loop",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@not(\n    empty(\n        variables('batchFailures')\n    )\n)",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "Failure detected",
							"type": "Fail",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"message": {
									"value": "@concat(\n    'Some batches failed with the following errors: ',\n    variables('batchFailures')\n)",
									"type": "Expression"
								},
								"errorCode": "500"
							}
						}
					]
				}
			}
		],
		"parameters": {
			"stages_to_execute": {
				"type": "array",
				"defaultValue": []
			},
			"run_id": {
				"type": "string"
			},
			"override_config_file": {
				"type": "string"
			}
		},
		"variables": {
			"batchFailures": {
				"type": "Array",
				"defaultValue": []
			}
		},
		"folder": {
			"name": "utils"
		},
		"annotations": []
	}
}